// Phase 1 (Foundation) schema: languages + auth only.
// Later phases add Word/Tag/Deck/Card/Quiz/Question/Progress/QuizResult, one migration each.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model Language {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  users       User[]
  words       Word[]
  tags        Tag[]
  decks       Deck[]
  quizzes     Quiz[]
  feedSources FeedSource[]

  @@map("languages")
}

// An RSS feed shown on the Home tab for learners of this language.
model FeedSource {
  id         String   @id @default(cuid())
  languageId String
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  name       String
  url        String // RSS 2.0 feed URL

  @@unique([languageId, url])
  @@map("feed_sources")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String?
  name             String?
  role             Role     @default(USER)
  emailVerified    DateTime?
  image            String?
  activeLanguageId String?
  activeLanguage   Language? @relation(fields: [activeLanguageId], references: [id], onDelete: SetNull)
  accounts         Account[]
  sessions         Session[]
  decks            Deck[]
  progress         Progress[]
  createdAt        DateTime @default(now())

  @@map("users")
}

// Auth.js (NextAuth) adapter models — required by @auth/prisma-adapter.
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

// ---- Phase 2: content ----

enum WordType {
  NOUN
  VERB
  ADJECTIVE
  ADVERB
  PHRASE
  OTHER
}

// A Word row is either a single word or a full sentence/phrase. Same shape,
// so it reuses the Word model, cards, decks, import, quizzes and flashcards.
enum WordKind {
  WORD
  SENTENCE
}

model Word {
  id          String   @id @default(cuid())
  languageId  String
  language    Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  text        String
  translation String
  wordType    WordType @default(OTHER)
  kind        WordKind @default(WORD)
  tags        Tag[]
  cards       Card[]
  createdAt   DateTime @default(now())

  @@index([languageId])
  @@map("words")
}

model Tag {
  id         String   @id @default(cuid())
  languageId String
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  name       String
  words      Word[]

  @@unique([languageId, name])
  @@map("tags")
}

model Deck {
  id         String   @id @default(cuid())
  languageId String
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  title      String
  ownerId    String? // null = official/admin deck
  owner      User?    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  cards      Card[]
  createdAt  DateTime @default(now())

  @@index([languageId])
  @@index([ownerId])
  @@map("decks")
}

model Card {
  id     String  @id @default(cuid())
  deckId String
  deck   Deck    @relation(fields: [deckId], references: [id], onDelete: Cascade)
  front  String
  back   String
  wordId   String?
  word     Word?      @relation(fields: [wordId], references: [id], onDelete: SetNull)
  progress Progress[]

  @@index([deckId])
  @@map("cards")
}

// Leitner spaced repetition: one row per user+card, box 1–5, next due date.
model Progress {
  userId String
  cardId String
  box    Int      @default(1)
  dueAt  DateTime @default(now())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card   Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@id([userId, cardId])
  @@index([userId, dueAt])
  @@map("progress")
}

model Quiz {
  id         String     @id @default(cuid())
  languageId String
  language   Language   @relation(fields: [languageId], references: [id], onDelete: Cascade)
  title      String
  questions  Question[]
  createdAt  DateTime   @default(now())

  @@index([languageId])
  @@map("quizzes")
}

model Question {
  id           String @id @default(cuid())
  quizId       String
  quiz         Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  prompt       String
  options      Json
  correctIndex Int

  @@index([quizId])
  @@map("questions")
}
