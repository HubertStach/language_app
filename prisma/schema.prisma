// Phase 1 (Foundation) schema: languages + auth only.
// Later phases add Word/Tag/Deck/Card/Quiz/Question/Progress/QuizResult, one migration each.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model Language {
  id    String @id @default(cuid())
  code  String @unique
  name  String
  users User[]

  @@map("languages")
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String?
  name             String?
  role             Role     @default(USER)
  emailVerified    DateTime?
  image            String?
  activeLanguageId String?
  activeLanguage   Language? @relation(fields: [activeLanguageId], references: [id], onDelete: SetNull)
  accounts         Account[]
  sessions         Session[]
  createdAt        DateTime @default(now())

  @@map("users")
}

// Auth.js (NextAuth) adapter models — required by @auth/prisma-adapter.
model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}
